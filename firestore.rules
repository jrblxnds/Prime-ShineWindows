rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email in [
          'ptecsonmedia@gmail.com', 
          'shepherd.burke16@gmail.com'
        ] &&
        request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Booking validation
    function isValidBooking(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() >= 10 &&
             data.email is string && data.email.matches('^.+@.+\\..+$') &&
             data.address is string && data.address.size() > 0 &&
             data.serviceType is string &&
             data.propertyType is string &&
             data.preferredDate is string && data.preferredDate.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.preferredTime is string &&
             data.dateTimeKey is string &&
             data.status in ['Pending', 'Confirmed', 'Completed', 'Cancelled'];
    }

    match /bookings/{bookingId} {
      // Public can create bookings
      allow create: if isValidId(bookingId) && 
                      isValidBooking(request.resource.data) &&
                      request.resource.data.status == 'Pending';
      
      // Only admins can read, update, or delete
      allow read, update, delete: if isAdmin();
    }

    match /blockedSlots/{slotId} {
      // Public can create a blocked slot as part of a transaction when booking
      // Note: We check if it already exists in the code-side transaction, 
      // but rules also protect against overwriting.
      allow create: if isValidId(slotId) &&
                      request.resource.data.dateTimeKey == slotId &&
                      request.resource.data.status in ['Pending', 'Confirmed'];
      
      // Admins can manage blocked slots
      allow read, update, delete: if isAdmin();
    }
  }
}
